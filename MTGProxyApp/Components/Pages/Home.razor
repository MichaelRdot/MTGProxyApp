@page "/"
@using System
@using System.Text.RegularExpressions
@using MTGProxyApp.Services

@using MTGProxyApp.Dtos
@inject IJSRuntime JS
@inject ScryfallService Scryfall

<h1 class="sr-only">MTG Proxy Builder</h1>

@if (Busy)
{
  <div class="overlay" role="alert" aria-live="assertive" aria-busy="true">
    <div class="overlay-box">
      <div class="spinner" aria-hidden="true"></div>
      <div>@BusyMessage</div>
    </div>
  </div>
}

<!-- Top actions -->
<div class="actions actions-top">
  <button class="btn btn-primary" disabled="@Busy" @onclick="ParseAndLoad_Wrapper">Parse &amp; Load</button>
  <button class="btn" disabled="@Busy" @onclick="SaveImagesZip_Wrapper">Save Images</button>
  <button class="btn" disabled="@Busy" @onclick="SaveAsPdfSheets_Wrapper">Download PDF Sheets</button>
  <label class="toggle"><input type="checkbox" @bind="HighResOnly" /> High-res only</label>
</div>

<!-- Deck textarea -->
<div class="editor">
  <textarea class="deck-input" @bind="DeckText" ...>
            placeholder="Paste deck list here (e.g.&#10;1 Nissa, Worldsoul Speaker (DRC) 13&#10;1 Nissa, Worldsoul Speaker)"></textarea>
</div>

<!-- Parsed cards grid -->
@if (Cards.Count > 0)
{
  <div class="cards">
    @foreach (var c in Cards)
    {
      <div class="card">
        <div class="card-head">
          <div class="title">@c.Quantity × @c.DisplayName</div>
          <div class="meta">
            @if (!string.IsNullOrWhiteSpace(c.SetCode) && !string.IsNullOrWhiteSpace(c.Collector))
            {
              <span>(@c.SetCode.ToUpperInvariant()) @c.Collector</span>
            }
          </div>
        </div>

        <div class="card-body">
          @if (c.PngUri is not null)
          {
            <img class="thumb" src="@c.PngUri" alt="@c.DisplayName" />
          }
          else
          {
            <div class="thumb thumb-empty">no art</div>
          }
          <div class="card-actions">
            <button class="btn" @onclick="@(()=>OpenArtPicker(c))">Choose alternate art</button>
          </div>
        </div>
      </div>
    }
  </div>

  <!-- Bottom actions -->
  <div class="actions actions-bottom">
    <button class="btn" disabled="@Busy" @onclick="SaveImagesZip_Wrapper">Save Images</button>
    <button class="btn btn-primary" disabled="@Busy" @onclick="SaveAsPdfSheets_Wrapper">Download PDF Sheets</button>
  </div>
}

<!-- Art picker modal -->
@if (ShowPicker && PickerFor is not null)
{
  <div class="modal-backdrop" @onclick="ClosePicker">
    <div class="modal" @onclick:stopPropagation>
      <div class="modal-header sticky">
        <div>
          Select art for <strong>@PickerFor.DisplayName</strong>
          @if (!string.IsNullOrWhiteSpace(PickerFor.SetCode) && !string.IsNullOrWhiteSpace(PickerFor.Collector))
          {
            <span class="meta"> — (@PickerFor.SetCode.ToUpperInvariant()) @PickerFor.Collector</span>
          }
        </div>
        <button class="btn" @onclick="ClosePicker">✕</button>
      </div>

      <div class="modal-body">
        @if (PickerOptions.Count == 0)
        {
          <div class="empty">No images found.</div>
        }
        else
        {
          <div class="picker-grid">
            @foreach (var opt in PickerOptions)
            {
              <button class="picker-item" @onclick="@(()=>PickArt(opt))" title="@opt.Set (@opt.Set?.ToUpperInvariant()) #@opt.SetId">
                @if (opt.ImageUris?.Png is Uri u)
                {
                  <img src="@u" alt="@opt.Name" />
                }
                <div class="picker-caption">
                  (@opt.Set?.ToUpperInvariant()) @opt.SetId
                </div>
              </button>
            }
          </div>
        }
      </div>

      <div class="modal-footer">
        @if (!string.IsNullOrEmpty(PrintsNextPage))
        {
          <button class="btn" @onclick="LoadMorePrints">Load more</button>
        }
        <button class="btn" @onclick="ClosePicker">Close</button>
      </div>
    </div>
  </div>
}

@code {
  // === Busy overlay state ===
  private bool Busy;
  private string BusyMessage = "Working…";
  private async Task SetBusy(bool value, string? message = null)
  {
    Busy = value;
    if (!string.IsNullOrWhiteSpace(message)) BusyMessage = message!;
    StateHasChanged();
    await JS.InvokeVoidAsync("ui.setBodyClass", "busy-open", Busy);
  }

  // === Deck text and parsed cards ===
  private string DeckText = string.Empty;

  private class ChosenCard
  {
    public string DisplayName { get; set; } = "";
    public int Quantity { get; set; } = 1;

    public Uri? PngUri { get; set; }
    public string? SelectedImageUrl { get; set; }

    public string? SetCode { get; set; }
    public string? Collector { get; set; }
    public string? ScryfallId { get; set; }

    public int LineIndex { get; set; } = -1;
  }

  private List<ChosenCard> Cards = new();

  private bool HighResOnly = true;

  private static readonly Regex RxFull = new(
      @"^\s*(?<qty>\d+)\s+(?<name>.+?)\s*\(\s*(?<set>[A-Za-z0-9]{2,5})\s*\)\s*(?<cn>[\w\-]+)\s*$",
      RegexOptions.Compiled);

  private static readonly Regex RxShort = new(
      @"^\s*(?<qty>\d+)\s+(?<name>.+?)\s*$",
      RegexOptions.Compiled);

  private sealed class ParsedLine
  {
    public int Qty { get; init; }
    public string Name { get; init; } = "";
    public string? Set { get; init; }
    public string? Collector { get; init; }
  }

  private static ParsedLine? ParseDeckLine(string line)
  {
    var m = RxFull.Match(line);
    if (m.Success)
      return new ParsedLine {
        Qty = int.Parse(m.Groups["qty"].Value),
        Name = m.Groups["name"].Value.Trim(),
        Set = m.Groups["set"].Value.Trim(),
        Collector = m.Groups["cn"].Value.Trim()
      };

    m = RxShort.Match(line);
    if (m.Success)
      return new ParsedLine {
        Qty = int.Parse(m.Groups["qty"].Value),
        Name = m.Groups["name"].Value.Trim()
      };

    return null;
  }

  private static string NormalizeLine(ChosenCard c)
  {
    var set = (c.SetCode ?? "").ToUpperInvariant();
    var cn  = c.Collector ?? "";
    return $"{c.Quantity} {c.DisplayName}" + (string.IsNullOrWhiteSpace(set) || string.IsNullOrWhiteSpace(cn)
      ? ""
      : $" ({set}) {cn}");
  }

  private void ReplaceLineAt(int index, string newLine)
  {
    var lines = DeckText.Replace("\r\n", "\n").Split('\n').ToList();
    if (index < 0 || index >= lines.Count) return;
    lines[index] = newLine;
    DeckText = string.Join(Environment.NewLine, lines);
  }

  private void OnDeckTextChanged(string _) { }

  // === Parse & Load ===
  private async Task ParseAndLoad_Wrapper()
  {
    await SetBusy(true, "Parsing deck and fetching cards…");
    try { await ParseAndLoadCore(); }
    finally { await SetBusy(false); }
  }

  private async Task ParseAndLoadCore()
  {
    Cards.Clear();

    var lines = DeckText.Replace("\r\n","\n").Split('\n');
    for (int i = 0; i < lines.Length; i++)
    {
      var raw = lines[i].Trim();
      if (string.IsNullOrWhiteSpace(raw)) continue;

      var parsed = ParseDeckLine(raw);
      if (parsed is null) continue;

      CardDto? printing = null;

      if (!string.IsNullOrWhiteSpace(parsed.Set) && !string.IsNullOrWhiteSpace(parsed.Collector))
      {
        printing = await Scryfall.GetCardBySetAndCollectorAsync(parsed.Set!, parsed.Collector!);
      }
      else
      {
        // implement in ScryfallService (see step 3 below)
        printing = await Scryfall.GetBestPrintingForNameAsync(parsed.Name);
      }

      if (printing is null) continue;

      if (HighResOnly && !string.Equals(printing.ImageStatus, "highres_scan", StringComparison.OrdinalIgnoreCase))
        continue;

      var chosen = new ChosenCard
      {
        DisplayName = printing.Name ?? parsed.Name,
        Quantity = parsed.Qty,
        PngUri = printing.ImageUris?.Png,
        SelectedImageUrl = printing.ImageUris?.Png?.ToString(),
        SetCode = printing.Set,
        Collector = printing.SetId,
        ScryfallId = printing.Id,
        LineIndex = i
      };

      Cards.Add(chosen);

      if (parsed.Set is null || parsed.Collector is null)
      {
        var norm = NormalizeLine(chosen);
        ReplaceLineAt(i, norm);
      }
    }

    StateHasChanged();
  }
  
  private void PickArt(CardDto picked)
  {
    if (PickerFor is null) return;

    // Persist the exact printing and selected art
    PickerFor.PngUri = picked.ImageUris?.Png ?? PickerFor.PngUri;
    PickerFor.SelectedImageUrl = PickerFor.PngUri?.ToString();
    PickerFor.SetCode   = picked.Set            ?? PickerFor.SetCode;
    PickerFor.Collector = picked.SetId          ?? PickerFor.Collector;
    PickerFor.ScryfallId= picked.Id             ?? PickerFor.ScryfallId;

    // Rewrite the corresponding deck line in the textarea to the normalized format:
    // "QTY Name (SET) COLLECTOR#"
    if (PickerFor.LineIndex >= 0)
    {
      var normalized = NormalizeLine(PickerFor);
      ReplaceLineAt(PickerFor.LineIndex, normalized);
    }

    // Close the modal
    ClosePicker();
  }

  // === Save images (ZIP) ===
  private async Task SaveImagesZip_Wrapper()
  {
    var deckName = await JSPrompt("Enter deck name for images:");
    if (string.IsNullOrWhiteSpace(deckName)) return;

    var urls = Cards
      .SelectMany(c => Enumerable.Repeat(c.SelectedImageUrl ?? c.PngUri?.ToString() ?? "", c.Quantity))
      .Where(s => !string.IsNullOrWhiteSpace(s))
      .ToList();
    if (urls.Count == 0) return;

    var payload = new { DeckName = deckName.Trim(), ImageUrls = urls };

    await SetBusy(true, "Preparing resized images…");
    try
    {
      await JS.InvokeVoidAsync("postAndDownload", "api/save-deck", payload, $"{deckName}.zip");
    }
    finally { await SetBusy(false); }
  }

  // === Save PDF (3×3 sheets) ===
  private async Task SaveAsPdfSheets_Wrapper()
  {
    var deckName = await JSPrompt("Enter deck name:");
    if (string.IsNullOrWhiteSpace(deckName)) return;

    var urls = Cards
      .SelectMany(c => Enumerable.Repeat(c.SelectedImageUrl ?? c.PngUri?.ToString() ?? "", c.Quantity))
      .Where(s => !string.IsNullOrWhiteSpace(s))
      .ToList();
    if (urls.Count == 0) return;

    var payload = new { DeckName = deckName.Trim(), ImageUrls = urls };

    await SetBusy(true, "Generating PDF…");
    try
    {
      await JS.InvokeVoidAsync("postAndDownload", "api/save-deck-sheets", payload, $"{deckName}.pdf");
    }
    finally { await SetBusy(false); }
  }

  private Task<string?> JSPrompt(string message) =>
      JS.InvokeAsync<string?>("prompt", message).AsTask();

  // === Art picker state ===
  private bool ShowPicker;
  private ChosenCard? PickerFor;
  private List<CardDto> PickerOptions = new();
  private string? PrintsNextPage;

  private async Task OpenArtPicker(ChosenCard c)
  {
    PickerFor = c;
    PickerOptions.Clear();
    PrintsNextPage = null;

    var seed = !string.IsNullOrWhiteSpace(c.SetCode) && !string.IsNullOrWhiteSpace(c.Collector)
      ? await Scryfall.GetCardBySetAndCollectorAsync(c.SetCode!, c.Collector!)
      : await Scryfall.GetBestPrintingForNameAsync(c.DisplayName);

    if (seed is not null)
    {
      var page = await Scryfall.GetPrintsPageAsync(new Uri(seed.PrintsSearchUri.ToString()));
      var list = page.Data;

      if (HighResOnly)
        list = list.Where(p => string.Equals(p.ImageStatus, "highres_scan", StringComparison.OrdinalIgnoreCase)).ToList();

      PickerOptions.AddRange(list);
      PrintsNextPage = page.NextPage;
    }

    ShowPicker = true;
    StateHasChanged();
    await JS.InvokeVoidAsync("ui.addBodyClass", "modal-open");
  }

  private async Task LoadMorePrints()
  {
    if (string.IsNullOrWhiteSpace(PrintsNextPage)) return;
    var page = await Scryfall.GetPrintsPageAsync(new Uri(PrintsNextPage));
    var list = page.Data;

    if (HighResOnly)
      list = list.Where(p => string.Equals(p.ImageStatus, "highres_scan", StringComparison.OrdinalIgnoreCase)).ToList();

    PickerOptions.AddRange(list);
    PrintsNextPage = page.NextPage;
    StateHasChanged();
  }

  private async void ClosePicker()
  {
    ShowPicker = false;
    PickerFor = null;
    PickerOptions.Clear();
    PrintsNextPage = null;
    await JS.InvokeVoidAsync("ui.removeBodyClass", "modal-open");
    StateHasChanged();
  }
}
