@page "/"
@using System.Text.RegularExpressions
@using MTGProxyApp.Dtos
@using MTGProxyApp.Services
@using Microsoft.JSInterop
@inject ScryfallService Scryfall
@inject ILogger<Home> Logger
@inject IJSRuntime JS
@rendermode InteractiveServer


<div class="page">
  <h1>MTG Proxy Builder</h1>

  <div class="controls">
    <textarea class="deck" placeholder="Paste decklist here (e.g.\n4 Lightning Bolt\n2 Ponder\n1 Sol Ring (CMM) 412)" @bind=deckText></textarea>

    <input class="deck-name" placeholder="Deck name (for PDF file)" @bind=deckName />

    <div class="buttons">
      <button type="button" @onclick="ParseAndLoadAsync" disabled="@isLoading">@((isLoading ? "Loading…" : "Parse & Load"))</button>
      <button type="button" @onclick="Clear" disabled="@isLoading">Clear</button>
      <button type="button" @onclick="SaveAsPdfAsync" disabled="@(isLoading || cards.Count == 0)">Save as PDF</button>
    </div>

    <div class="status" hidden="@string.IsNullOrWhiteSpace(status)">
      <pre>@status</pre>
    </div>
  </div>

  <div class="results" hidden="@(cards.Count == 0)">
    <h2>Results (@cards.Count cards)</h2>
    <div class="grid">
      @foreach (var c in cards)
      {
        <div class="card">
          <div class="thumb">
            @if (!string.IsNullOrWhiteSpace(c.ImageUrl))
            {
              <img @onclick="() => OpenArtPickerAsync(c)" style="cursor:pointer" src="@c.ImageUrl" alt="@c.DisplayName" />
            }
            else
            {
              <div class="placeholder">No image</div>
            }
          </div>
          <div class="meta">
            <div class="name" title="@c.DisplayName">@c.DisplayName</div>
            <div class="details">@c.Set?.ToUpper() @c.Collector</div>
            <div class="qty">@c.Qty</div>
          </div>
        </div>
      }
    </div>
  </div>
</div>

@code {
  // --- Save as PDF ---
  private string deckName = string.Empty;

  private async Task SaveAsPdfAsync()
  {
    var images = cards
      .Where(c => !string.IsNullOrWhiteSpace(c.ImageUrl))
      .SelectMany(c => Enumerable.Repeat(c.ImageUrl!, Math.Max(1, c.Qty)))
      .ToList();

    if (images.Count == 0)
      return;

    var payload = new { DeckName = string.IsNullOrWhiteSpace(deckName) ? "MTG Proxies" : deckName, ImageUrls = images };
    await JS.InvokeVoidAsync("postAndDownload", "/api/save-deck-sheFetchCardVmAsyncets", payload, $"{(string.IsNullOrWhiteSpace(deckName) ? "MTG Proxies" : deckName)}.pdf");
  }
  
  // --- Normalizer ---
  private static string NormalizeLine(ProxyCardVm c)
  {
    var setPart = (!string.IsNullOrWhiteSpace(c.Set) && !string.IsNullOrWhiteSpace(c.Collector))
      ? $" ({c.Set!.ToUpperInvariant()}) {c.Collector}"
      : string.Empty;

    return $"{c.Qty} {c.DisplayName}{setPart}";
  }

  // --- Art picker ---
  private bool showArtPicker = false;
  private ProxyCardVm? selectedCard;
  private List<ArtOption> artOptions = new();
  private Uri? nextPrintsPage;
  private bool isLoadingArts = false;

  private sealed class ArtOption
  {
    public required string ImageUrl { get; init; }
    public string? Set { get; init; }
    public string? Collector { get; init; }
  }

  private async Task OpenArtPickerAsync(ProxyCardVm card)
  {
    selectedCard = card;
    artOptions.Clear();
    showArtPicker = true;
    nextPrintsPage = card.PrintsSearchUri;
    await LoadMoreArtsAsync();
  }

  private async Task LoadMoreArtsAsync()
  {
    if (nextPrintsPage is null) return;
    isLoadingArts = true;

    var page = await Scryfall.GetPrintsPageAsync(nextPrintsPage);
    nextPrintsPage = string.IsNullOrWhiteSpace(page.NextPage) ? null : new Uri(page.NextPage);

    foreach (var d in page.Data)
    {
      var url = d.ImageUris?.Png?.ToString();
      if (!string.IsNullOrWhiteSpace(url))
        artOptions.Add(new ArtOption { ImageUrl = url!, Set = d.Set, Collector = d.CollectorNumber });
    }

    isLoadingArts = false;
    StateHasChanged();
  }

  private void ChooseArt(ArtOption opt)
  {
    if (selectedCard is null) return;

    selectedCard.ImageUrl = opt.ImageUrl;
    if (!string.IsNullOrWhiteSpace(opt.Set)) selectedCard.Set = opt.Set;
    if (!string.IsNullOrWhiteSpace(opt.Collector)) selectedCard.Collector = opt.Collector;

    // Rebuild the deck text to reflect the chosen printing
    deckText = string.Join("\n", cards.Select(NormalizeLine));

    showArtPicker = false;
  }

  private void CloseArtPicker()
  {
    showArtPicker = false;
  }

  // ---------------------------------------------------------
  // View model types (kept local to this page for simplicity)
  // ---------------------------------------------------------
  private sealed record ParsedLine(int Qty, string Name, string? Set, string? Collector);

  private sealed class ProxyCardVm
  {
    public required string DisplayName { get; init; }
    public required int Qty { get; init; }
    public string? ImageUrl { get; set; }
    public string? Set { get; set; }
    public string? Collector { get; set; }
    public string? ScryfallId { get; set; }
    public Uri? PrintsSearchUri { get; init; }
  }

  // ---------------------------------------------------------
  // State
  // ---------------------------------------------------------
  private string deckText = string.Empty;
  private bool isLoading = false;
  private string status = string.Empty;
  private List<ProxyCardVm> cards = new();
  private CancellationTokenSource? _cts;

  // ---------------------------------------------------------
  // UI handlers
  // ---------------------------------------------------------
  private async Task ParseAndLoadAsync()
  {
    if (isLoading)
      return;

    isLoading = true;
    status = string.Empty;
    cards.Clear();
    _cts?.Cancel();
    _cts = new CancellationTokenSource();
    var token = _cts.Token;

    try
    {
      var parsed = ParseDeckText(deckText).ToList();
      if (parsed.Count == 0)
      {
        status = "No parsable card lines found.";
        return;
      }

      status = $"Parsed {parsed.Count} line(s). Fetching printings…";
      StateHasChanged();

      // Fetch concurrently, but be gentle — limit parallelism
      var throttler = new SemaphoreSlim(8);
      var results = new List<ProxyCardVm>();

      var tasks = parsed.Select(async line =>
      {
        await throttler.WaitAsync(token);
        try
        {
          var vm = await FetchCardVmAsync(line, token);
          if (vm != null)
          {
            lock (results)
            {
              results.Add(vm);
            }
          }
        }
        catch (Exception ex)
        {
          Logger.LogError(ex, "Failed to fetch card for {Line}", line);
          lock (results)
          {
            // Add a placeholder so the user sees which one failed
            results.Add(new ProxyCardVm
            {
              DisplayName = $"{line.Name} (failed)",
              Qty = line.Qty,
              ImageUrl = null,
              Set = line.Set,
              Collector = line.Collector,
              ScryfallId = null
            });
          }
        }
        finally
        {
          throttler.Release();
        }
      }).ToList();

      await Task.WhenAll(tasks);

      // Expand quantities into individual proxies later — for now keep qty
      cards = results
        .OrderBy(c => c.DisplayName, StringComparer.OrdinalIgnoreCase)
        .ToList();
      deckText = string.Join("\n", cards.Select(NormalizeLine));
      status = "Done.";
    }
    finally
    {
      isLoading = false;
      await InvokeAsync(StateHasChanged);
    }
  }

  private void Clear()
  {
    deckText = string.Empty;
    cards.Clear();
    status = string.Empty;
  }

  // ---------------------------------------------------------
  // Parsing + Fetching
  // ---------------------------------------------------------
  private static IEnumerable<ParsedLine> ParseDeckText(string text)
  {
    if (string.IsNullOrWhiteSpace(text))
      yield break;

    // Pattern: [qty] [name] [(SET) collector]
    // Examples:
    // 4 Lightning Bolt
    // 2 Ponder
    // 1 Sol Ring (CMM) 412
    // 3 Thoughtseize (LRW) 145
    var rx = new Regex(
      pattern: "^\\s*(?<qty>\\d+)?\\s*(?:x)?\\s*(?<name>[^()\\n]+?)(?:\\s*\\((?<set>[A-Za-z0-9]{2,5})\\)\\s*(?<coll>[^\\s]+))?\\s*$",
      options: RegexOptions.Multiline | RegexOptions.CultureInvariant);

    foreach (Match m in rx.Matches(text))
    {
      if (!m.Success) continue;
      var qty = 1;
      var qtyStr = m.Groups["qty"].Value;
      if (!string.IsNullOrWhiteSpace(qtyStr) && int.TryParse(qtyStr, out var q) && q > 0) qty = q;

      var name = m.Groups["name"].Value.Trim();
      if (string.IsNullOrWhiteSpace(name)) continue;

      var set = m.Groups["set"].Success ? m.Groups["set"].Value.Trim() : null;
      var coll = m.Groups["coll"].Success ? m.Groups["coll"].Value.Trim() : null;

      yield return new ParsedLine(qty, name, set, coll);
    }
  }

  private async Task<ProxyCardVm?> FetchCardVmAsync(ParsedLine line, CancellationToken ct)
  {
    CardDto? card = null;

    // Prefer explicit set+collector when provided
    if (!string.IsNullOrWhiteSpace(line.Set) && !string.IsNullOrWhiteSpace(line.Collector))
    {
      card = await Scryfall.GetCardBySetAndCollectorAsync(line.Set!, line.Collector!);
    }

    // Otherwise, try exact name, then fuzzy
    card ??= await Scryfall.GetBestPrintingForNameAsync(line.Name);

    if (card is null)
      return null;

    var img = card.ImageUris?.Png?.ToString()
              ?? card.CardFaces?.FirstOrDefault()?.ImageUris?.Png?.ToString();

    return new ProxyCardVm
    {
      DisplayName = card.Name ?? line.Name,
      Qty = line.Qty,
      ImageUrl = img,
      Set = card.Set,
      Collector = card.CollectorNumber,
      ScryfallId = card.Id, 
      PrintsSearchUri = card.PrintsSearchUri
    };
  }
}


  @if (showArtPicker && selectedCard is not null)
  {
    <div class="art-picker-backdrop" @onclick="CloseArtPicker">
      <div class="art-picker" @onclick:stopPropagation="true">
        <div class="art-picker-header">
          <strong>Choose art for @selectedCard.DisplayName</strong>
          <button type="button" class="close" @onclick="CloseArtPicker">✕</button>
        </div>
        <div class="art-picker-grid">
          @foreach (var opt in artOptions)
          {
            <button type="button" class="art-option" title="@($"{opt.Set?.ToUpper()} {opt.Collector}")" @onclick="() => ChooseArt(opt)">
              <img src="@opt.ImageUrl" alt="@($"{opt.Set} {opt.Collector}")" />
            </button>
          }
        </div>
        <div class="art-picker-footer">
          <button type="button" disabled="@(isLoadingArts || nextPrintsPage is null)" @onclick="LoadMoreArtsAsync">
            @(isLoadingArts ? "Loading…" : (nextPrintsPage is null ? "No more" : "Load more"))
          </button>
        </div>
      </div>
    </div>
  }

<style>
.page { max-width: 1100px; margin: 2rem auto; padding: 0 1rem; }
.controls { display: grid; gap: 0.75rem; }
.deck { width: 100%; min-height: 220px; font: 14px/1.35 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; padding: .75rem; }
.buttons { display:flex; gap:.5rem; }
.buttons button { padding: .5rem .9rem; }
.status pre { background:#666; padding:.5rem .75rem; border-radius:6px; white-space:pre-wrap; }
.results { margin-top:1.25rem; }
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }
.card { border: 1px solid #e5e5e5; border-radius: 10px; padding: 10px; display:flex; flex-direction:column; gap:.5rem; }
.thumb { width: 100%; aspect-ratio: 63/88; display:grid; place-items:center; background:#fafafa; border-radius:8px; overflow:hidden; }
.thumb img { width: 100%; height: 100%; object-fit: cover; }
.placeholder { color:#888; font-size: 12px; }
.meta { display:flex; align-items: center; justify-content: space-between; gap:.5rem; }
.name { font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.details { font-size:12px; color:#666; }
.qty { font-weight:600; }

.art-picker-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.45); display:grid; place-items:center; z-index: 1000; }
.art-picker { background: rgba(0,0,0,.45); border-radius: 10px; width: min(900px, 92vw); max-height: 90vh; overflow: auto; padding: 1rem; display:flex; flex-direction:column; gap:.75rem; }
.art-picker-header { display:flex; align-items:center; justify-content: space-between; }
.art-picker-grid { display:grid; grid-template-columns: repeat(auto-fill, minmax(140px,1fr)); gap: .5rem; }
.art-option { padding: 0; border: none; background: transparent; cursor: pointer; }
.art-option img { width: 100%; aspect-ratio: 63 / 88; object-fit: cover; display:block; border-radius: 6px; }
.art-picker-footer { display:flex; justify-content:center; margin-top: .5rem; }
.deck-name { width: 100%; padding: .5rem .75rem; border: 1px solid #e5e5e5; border-radius: 6px; font: inherit; }

</style>
